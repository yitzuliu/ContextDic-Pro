# ContextDic Pro Backend - Environment Variables
# Copy this file to .env and fill in your actual values

# Google Gemini API Key (SERVER-SIDE ONLY - never expose to the extension)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Shared secret for authenticating requests from the Chrome extension.
# Generate a strong random string and set the same value in the extension
# settings under "API Secret".  Leave empty to disable auth (dev only).
API_SECRET=your_shared_secret_here

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# CORS Configuration
# Comma-separated list of allowed origins. Restrict in production.
CORS_ORIGINS=chrome-extension://*,http://localhost:*

# Rate Limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60

# Gemini model generation timeout (seconds)
REQUEST_TIMEOUT_SECONDS=15

# Logging Level
LOG_LEVEL=INFO
